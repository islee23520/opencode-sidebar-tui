{
  "name": "opencode-sidebar-tui",
  "displayName": "OpenCode Sidebar TUI",
  "description": "Automatically render OpenCode TUI in VS Code sidebar with full terminal support",
  "version": "1.5.0",
  "publisher": "islee23520",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.106.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "opencode",
    "terminal",
    "sidebar",
    "tui",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": " https://github.com/islee23520/opencode-sidebar-tui"
  },
  "license": "MIT",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencodeTuiContainer",
          "title": "OpenCode",
          "icon": "resources/opencode-activity-bar.svg"
        }
      ]
    },
    "views": {
      "opencodeTuiContainer": [
        {
          "id": "opencodeTui",
          "name": "Terminal",
          "type": "webview",
          "icon": "$(terminal)",
          "contextualTitle": "OpenCode TUI"
        },
        {
          "id": "opencodeTui.instancesDashboard",
          "name": "Instances",
          "type": "webview",
          "icon": "$(server)",
          "contextualTitle": "OpenCode Instances"
        }
      ]
    },
    "commands": [
      {
        "command": "opencodeTui.open",
        "title": "Open OpenCode Sidebar",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.focus",
        "title": "Focus OpenCode Sidebar",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.start",
        "title": "Start OpenCode",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.sendToTerminal",
        "title": "Send to OpenCode Terminal",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.sendAtMention",
        "title": "Send File Reference (@file)",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.sendAllOpenFiles",
        "title": "Send All Open File References",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.sendFileToTerminal",
        "title": "Send to OpenCode",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.restart",
        "title": "Restart OpenCode",
        "category": "OpenCode TUI",
        "icon": "$(debug-restart)"
      },
      {
        "command": "opencodeTui.tmux.attach",
        "title": "Attach to Tmux Session",
        "category": "OpenCode TUI",
        "icon": "$(terminal-tmux)"
      },
      {
        "command": "opencodeTui.tmux.create",
        "title": "Create Tmux Session",
        "category": "OpenCode TUI",
        "icon": "$(add)"
      },
      {
        "command": "opencodeTui.tmux.detach",
        "title": "Detach from Tmux",
        "category": "OpenCode TUI",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "opencodeTui.paste",
        "title": "Paste",
        "category": "OpenCode TUI",
        "icon": "$(clippy)"
      },
      {
        "command": "opencode.openInNewWindow",
        "title": "Open Instance in New Window",
        "category": "OpenCode TUI",
        "icon": "$(empty-window)"
      },
      {
        "command": "opencode.spawnForWorkspace",
        "title": "Spawn Instance for Workspace",
        "category": "OpenCode TUI",
        "icon": "$(add)"
      },
      {
        "command": "opencodeTui.selectInstance",
        "title": "Select OpenCode Instance",
        "category": "OpenCode TUI",
        "icon": "$(server-environment)"
      },
      {
        "command": "opencodeTui.createTab",
        "title": "Create New Tab",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.createTab.opencode",
        "title": "Create OpenCode Tab",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.createTab.claude",
        "title": "Create Claude Tab",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.createTab.codex",
        "title": "Create Codex Tab",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.createTab.gemini",
        "title": "Create Gemini Tab",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.createTab.aider",
        "title": "Create Aider Tab",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.closeTab",
        "title": "Close Current Tab",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.nextTab",
        "title": "Next Tab",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.previousTab",
        "title": "Previous Tab",
        "category": "OpenCode TUI"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "opencodeTui.restart",
          "when": "view == opencodeTui",
          "group": "navigation@1"
        },
        {
          "command": "opencodeTui.tmux.attach",
          "when": "view == opencodeTui",
          "group": "navigation@2"
        },
        {
          "command": "opencodeTui.tmux.create",
          "when": "view == opencodeTui",
          "group": "navigation@3"
        },
        {
          "command": "opencodeTui.tmux.detach",
          "when": "view == opencodeTui",
          "group": "navigation@4"
        }
      ],
      "explorer/context": [
        {
          "command": "opencodeTui.sendFileToTerminal",
          "group": "2_workspace",
          "when": "!explorerResourceIsFolder"
        },
        {
          "command": "opencodeTui.sendFileToTerminal",
          "group": "2_workspace",
          "when": "explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "opencodeTui.sendAtMention",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opencodeTui.sendAtMention",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "opencodeTui.sendAllOpenFiles",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "-workbench.action.quickOpen",
        "key": "ctrl+p",
        "when": "focusedView == 'opencodeTui'"
      },
      {
        "command": "-workbench.action.quickOpenNavigateNextInFilePicker",
        "key": "ctrl+p",
        "when": "inFilesPicker && inQuickOpen"
      },
      {
        "command": "opencodeTui.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == 'opencodeTui'"
      },
      {
        "command": "opencodeTui.createTab",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "focusedView == 'opencodeTui'"
      },
      {
        "command": "opencodeTui.closeTab",
        "key": "ctrl+alt+w",
        "mac": "cmd+alt+w",
        "when": "focusedView == 'opencodeTui'"
      },
      {
        "command": "opencodeTui.nextTab",
        "key": "ctrl+alt+right",
        "mac": "cmd+alt+right",
        "when": "focusedView == 'opencodeTui'"
      },
      {
        "command": "opencodeTui.previousTab",
        "key": "ctrl+alt+left",
        "mac": "cmd+alt+left",
        "when": "focusedView == 'opencodeTui'"
      }
    ],
    "configuration": {
      "title": "OpenCode Sidebar TUI",
      "properties": {
        "opencodeTui.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start OpenCode when the view is activated"
        },
        "opencodeTui.command": {
          "type": "string",
          "default": "opencode -c",
          "description": "Command to launch OpenCode with arguments"
        },
        "opencodeTui.fontSize": {
          "type": "number",
          "default": 14,
          "minimum": 6,
          "maximum": 25,
          "description": "Terminal font size in pixels"
        },
        "opencodeTui.fontFamily": {
          "type": "string",
          "default": "monospace",
          "description": "Terminal font family"
        },
        "opencodeTui.cursorBlink": {
          "type": "boolean",
          "default": true,
          "description": "Enable cursor blinking"
        },
        "opencodeTui.cursorStyle": {
          "type": "string",
          "default": "block",
          "enum": [
            "block",
            "underline",
            "bar"
          ],
          "description": "Cursor style"
        },
        "opencodeTui.scrollback": {
          "type": "number", 
          "default": 10000,
          "minimum": 0,
          "maximum": 100000,
          "description": "Maximum number of lines in scrollback buffer"
        },
        "opencodeTui.autoFocusOnSend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically focus the OpenCode sidebar after sending file references or text"
        },
        "opencodeTui.autoStartOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start OpenCode when the sidebar is opened (only when visible, not on VS Code reload)"
        },
        "opencodeTui.shellPath": {
          "type": "string",
          "default": "",
          "description": "Custom shell path to use for the terminal. Leave empty to use VS Code's default shell. Useful for specifying PowerShell, Git Bash, or other shells on Windows."
        },
        "opencodeTui.shellArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom arguments to pass to the shell. Leave empty for automatic detection. Example: [\"/c\"] for cmd.exe or [\"-Command\"] for PowerShell."
        },
        "opencodeTui.autoShareContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically share editor context (open files, selections) with OpenCode"
        },
        "opencodeTui.httpTimeout": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "HTTP API request timeout in milliseconds for communication with OpenCode"
        },
        "opencodeTui.enableHttpApi": {
          "type": "boolean",
          "default": true,
          "description": "Enable HTTP API for bidirectional communication between VS Code and OpenCode"
        },
        "opencodeTui.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Log output level for OpenCode TUI"
        },
        "opencodeTui.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show status bar item for quick access"
        },
        "opencodeTui.contextDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "Debounce delay for context updates (ms)"
        },
        "opencodeTui.maxDiagnosticLength": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 2000,
          "description": "Maximum length of diagnostic messages"
        },
        "opencodeTui.enableAutoSpawn": {
          "type": "boolean",
          "default": true,
          "description": "Auto-spawn OpenCode if not running"
        },
        "opencodeTui.codeActionSeverities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "information",
              "hint"
            ]
          },
          "default": [
            "error",
            "warning"
          ],
          "description": "Diagnostic severities that trigger code actions"
        },
        "opencodeTui.autoServe": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start OpenCode in background with serve mode on VS Code startup"
        },
        "opencodeTui.serveCommand": {
          "type": "string",
          "default": "opencode serve",
          "description": "Command to launch OpenCode in serve mode (background)"
        },
        "opencodeTui.tools.opencode": {
          "type": "object",
          "description": "OpenCode CLI settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable OpenCode tool"
            },
            "command": {
              "type": "string",
              "default": "opencode -c",
              "description": "Command to launch OpenCode"
            },
            "shellPath": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Custom shell path for OpenCode"
            },
            "shellArgs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Custom shell arguments for OpenCode"
            },
            "env": {
              "type": "object",
              "default": {},
              "description": "Environment variables for OpenCode"
            }
          }
        },
        "opencodeTui.tools.claude": {
          "type": "object",
          "description": "Claude CLI settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable Claude tool"
            },
            "command": {
              "type": "string",
              "default": "claude",
              "description": "Command to launch Claude"
            },
            "shellPath": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Custom shell path for Claude"
            },
            "shellArgs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Custom shell arguments for Claude"
            },
            "env": {
              "type": "object",
              "default": {},
              "description": "Environment variables for Claude"
            }
          }
        },
        "opencodeTui.tools.codex": {
          "type": "object",
          "description": "Codex CLI settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable Codex tool"
            },
            "command": {
              "type": "string",
              "default": "codex",
              "description": "Command to launch Codex"
            },
            "shellPath": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Custom shell path for Codex"
            },
            "shellArgs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Custom shell arguments for Codex"
            },
            "env": {
              "type": "object",
              "default": {},
              "description": "Environment variables for Codex"
            }
          }
        },
        "opencodeTui.tools.gemini": {
          "type": "object",
          "description": "Gemini CLI settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable Gemini tool"
            },
            "command": {
              "type": "string",
              "default": "gemini",
              "description": "Command to launch Gemini"
            },
            "shellPath": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Custom shell path for Gemini"
            },
            "shellArgs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Custom shell arguments for Gemini"
            },
            "env": {
              "type": "object",
              "default": {},
              "description": "Environment variables for Gemini"
            }
          }
        },
        "opencodeTui.tools.aider": {
          "type": "object",
          "description": "Aider CLI settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable Aider tool"
            },
            "command": {
              "type": "string",
              "default": "aider",
              "description": "Command to launch Aider"
            },
            "shellPath": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Custom shell path for Aider"
            },
            "shellArgs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Custom shell arguments for Aider"
            },
            "env": {
              "type": "object",
              "default": {},
              "description": "Environment variables for Aider"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build-and-install": "npx @vscode/vsce package -o build/extension.vsix && code --install-extension build/extension.vsix --force"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.2.0-beta.11"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@types/vscode": "^1.106.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "css-loader": "^7.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.0"
  }
}
