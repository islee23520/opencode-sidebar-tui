{
  "name": "opencode-sidebar-tui",
  "displayName": "Open AI Sidebar Terminal",
  "description": "Automatically render OpenCode TUI in VS Code sidebar with full terminal support",
  "version": "1.5.0",
  "publisher": "islee23520",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.106.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "opencode",
    "terminal",
    "sidebar",
    "tui",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": " https://github.com/islee23520/opencode-sidebar-tui"
  },
  "license": "MIT",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencodeTuiContainer",
          "title": "Open AI Sidebar Terminal",
          "icon": "resources/opencode-activity-bar.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "opencodeTuiTerminal",
          "title": "Terminal",
          "icon": "resources/opencode-activity-bar.svg"
        }
      ]
    },
    "views": {
      "opencodeTuiContainer": [
        {
          "id": "opencodeTui.terminalDashboard",
          "name": "Open AI Sidebar Terminal",
          "type": "webview",
          "icon": "resources/opencode-activity-bar.svg",
          "contextualTitle": "Open AI Sidebar Terminal"
        }
      ],
      "opencodeTuiTerminal": [
        {
          "id": "opencodeTui",
          "name": "Terminal",
          "type": "webview",
          "icon": "resources/opencode-activity-bar.svg",
          "contextualTitle": "OpenCode TUI"
        }
      ]
    },
    "commands": [
      {
        "command": "opencodeTui.start",
        "title": "Start OpenCode",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.sendToTerminal",
        "title": "Send to Active Terminal",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.sendAtMention",
        "title": "Send File Reference (@file)",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.sendAllOpenFiles",
        "title": "Send All Open File References",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.sendFileToTerminal",
        "title": "Send to OpenCode",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.paste",
        "title": "Paste",
        "category": "OpenCode TUI",
        "icon": "$(clippy)"
      },
      {
        "command": "opencode.openInNewWindow",
        "title": "Open Tmux Session in New Window",
        "category": "OpenCode TUI",
        "icon": "$(empty-window)"
      },
      {
        "command": "opencode.spawnForWorkspace",
        "title": "Spawn Tmux Session for Workspace",
        "category": "OpenCode TUI",
        "icon": "$(add)"
      },
      {
        "command": "opencodeTui.selectInstance",
        "title": "Select OpenCode Tmux Session",
        "category": "OpenCode TUI",
        "icon": "$(server-environment)"
      },
      {
        "command": "opencodeTui.switchTmuxSession",
        "title": "Switch Tmux Session",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.browseTmuxSessions",
        "title": "Browse Tmux Sessions",
        "category": "OpenCode TUI",
        "icon": "$(server-environment)"
      },
      {
        "command": "opencodeTui.switchNativeShell",
        "title": "Switch to Native Shell",
        "category": "OpenCode TUI"
      },
      {
        "command": "opencodeTui.openTerminalManager",
        "title": "Open Terminal Managers",
        "category": "OpenCode TUI",
        "icon": "$(server)"
      },
      {
        "command": "opencodeTui.tmuxSwitchPane",
        "title": "Switch to Pane",
        "category": "OpenCode TUI",
        "icon": "$(check)"
      },
      {
        "command": "opencodeTui.tmuxSplitPaneH",
        "title": "Split Pane Horizontal",
        "category": "OpenCode TUI",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "opencodeTui.tmuxSplitPaneV",
        "title": "Split Pane Vertical",
        "category": "OpenCode TUI",
        "icon": "$(split-vertical)"
      },
      {
        "command": "opencodeTui.tmuxSplitPaneWithCommand",
        "title": "Split Pane with Command",
        "category": "OpenCode TUI",
        "icon": "$(terminal)"
      },
      {
        "command": "opencodeTui.tmuxSendTextToPane",
        "title": "Send Text to Pane",
        "category": "OpenCode TUI",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "opencodeTui.tmuxResizePane",
        "title": "Resize Pane",
        "category": "OpenCode TUI",
        "icon": "$(move)"
      },
      {
        "command": "opencodeTui.tmuxSwapPane",
        "title": "Swap Panes",
        "category": "OpenCode TUI",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "opencodeTui.tmuxKillPane",
        "title": "Kill Pane",
        "category": "OpenCode TUI",
        "icon": "$(trash)"
      },
      {
        "command": "opencodeTui.tmuxNextWindow",
        "title": "Next Window",
        "category": "OpenCode TUI",
        "icon": "$(chevron-right)"
      },
      {
        "command": "opencodeTui.tmuxPrevWindow",
        "title": "Previous Window",
        "category": "OpenCode TUI",
        "icon": "$(chevron-left)"
      },
      {
        "command": "opencodeTui.tmuxCreateWindow",
        "title": "Create Window",
        "category": "OpenCode TUI",
        "icon": "$(add)"
      },
      {
        "command": "opencodeTui.tmuxKillWindow",
        "title": "Kill Window",
        "category": "OpenCode TUI",
        "icon": "$(trash)"
      },
      {
        "command": "opencodeTui.tmuxSelectWindow",
        "title": "Select Window",
        "category": "OpenCode TUI",
        "icon": "$(list-selection)"
      },
      {
        "command": "opencodeTui.tmuxKillSession",
        "title": "Kill Session",
        "category": "OpenCode TUI",
        "icon": "$(trash)"
      },
      {
        "command": "opencodeTui.tmuxRefresh",
        "title": "Refresh Terminal Manager",
        "category": "OpenCode TUI",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [],
      "explorer/context": [
        {
          "command": "opencodeTui.sendFileToTerminal",
          "group": "2_workspace",
          "when": "!explorerResourceIsFolder"
        },
        {
          "command": "opencodeTui.sendFileToTerminal",
          "group": "2_workspace",
          "when": "explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "opencodeTui.sendAtMention",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opencodeTui.sendAtMention",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "opencodeTui.sendAllOpenFiles",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "opencodeTui.browseTmuxSessions",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "focusedView == 'opencodeTui'"
      },
      {
        "command": "-workbench.action.quickOpen",
        "key": "ctrl+p",
        "when": "focusedView == 'opencodeTui'"
      },
      {
        "command": "-workbench.action.quickOpenNavigateNextInFilePicker",
        "key": "ctrl+p",
        "when": "inFilesPicker && inQuickOpen"
      },
      {
        "command": "opencodeTui.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == 'opencodeTui'"
      }
    ],
    "configuration": {
      "title": "OpenCode Sidebar TUI",
      "properties": {
        "opencodeTui.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start OpenCode when the view is activated"
        },
        "opencodeTui.command": {
          "type": "string",
          "default": "opencode",
          "description": "Legacy command override for OpenCode startup. Prefer opencodeTui.aiTools for multi-tool configuration."
        },
        "opencodeTui.fontSize": {
          "type": "number",
          "default": 14,
          "minimum": 6,
          "maximum": 25,
          "description": "Terminal font size in pixels"
        },
        "opencodeTui.fontFamily": {
          "type": "string",
          "default": "'JetBrainsMono Nerd Font', 'FiraCode Nerd Font', 'CascadiaCode NF', Menlo, monospace",
          "description": "Terminal font family (Nerd Font recommended for Powerline/glyph support)"
        },
        "opencodeTui.cursorBlink": {
          "type": "boolean",
          "default": true,
          "description": "Enable cursor blinking"
        },
        "opencodeTui.cursorStyle": {
          "type": "string",
          "default": "block",
          "enum": [
            "block",
            "underline",
            "bar"
          ],
          "description": "Cursor style"
        },
        "opencodeTui.scrollback": {
          "type": "number",
          "default": 10000,
          "minimum": 0,
          "maximum": 100000,
          "description": "Maximum number of lines in scrollback buffer"
        },
        "opencodeTui.autoFocusOnSend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically focus the OpenCode sidebar after sending file references or text"
        },
        "opencodeTui.autoStartOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start OpenCode when the sidebar is opened (only when visible, not on VS Code reload)"
        },
        "opencodeTui.shellPath": {
          "type": "string",
          "default": "",
          "description": "Custom shell path to use for the terminal. Leave empty to use VS Code's default shell. Useful for specifying PowerShell, Git Bash, or other shells on Windows."
        },
        "opencodeTui.shellArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom arguments to pass to the shell. Leave empty for automatic detection. Example: [\"/c\"] for cmd.exe or [\"-Command\"] for PowerShell."
        },
        "opencodeTui.autoShareContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically share editor context (open files, selections) with OpenCode"
        },
        "opencodeTui.httpTimeout": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "HTTP API request timeout in milliseconds for communication with OpenCode"
        },
        "opencodeTui.enableHttpApi": {
          "type": "boolean",
          "default": true,
          "description": "Enable HTTP API for bidirectional communication between VS Code and OpenCode"
        },
        "opencodeTui.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Log output level for OpenCode TUI"
        },
        "opencodeTui.contextDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "Debounce delay for context updates (ms)"
        },
        "opencodeTui.maxDiagnosticLength": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 2000,
          "description": "Maximum length of diagnostic messages"
        },
        "opencodeTui.enableAutoSpawn": {
          "type": "boolean",
          "default": true,
          "description": "Auto-spawn OpenCode if not running"
        },
        "opencodeTui.codeActionSeverities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "information",
              "hint"
            ]
          },
          "default": [
            "error",
            "warning"
          ],
          "description": "Diagnostic severities that trigger code actions"
        },
        "opencodeTui.aiTools": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique identifier for the AI tool"
              },
              "label": {
                "type": "string",
                "description": "Display name for the AI tool"
              },
              "path": {
                "type": "string",
                "description": "Path to the executable. Empty or unset = use bare command name (resolved from PATH)"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Default arguments to pass when launching this tool"
              },
              "aliases": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Additional names that should resolve to this tool"
              },
              "operator": {
                "type": "string",
                "description": "Optional operator id used to apply tool-specific launch and routing behavior"
              }
            },
            "required": [
              "name",
              "label"
            ]
          },
          "default": [
            {
              "name": "opencode",
              "label": "OpenCode",
              "path": "",
              "args": [
                "-c"
              ],
              "operator": "opencode"
            },
            {
              "name": "claude-code",
              "label": "Claude Code",
              "path": "",
              "args": [],
              "aliases": [
                "claude"
              ],
              "operator": "claude-code"
            },
            {
              "name": "codex",
              "label": "Codex",
              "path": "",
              "args": [],
              "operator": "codex"
            }
          ],
          "description": "Configure AI coding tools with custom paths, arguments, aliases, and operator ids"
        },
        "opencodeTui.defaultAiTool": {
          "type": "string",
          "default": "",
          "description": "Name of the default AI tool to launch when creating a new tmux session"
        },
        "opencodeTui.nativeShellDefault": {
          "type": "string",
          "default": "",
          "description": "Default behavior when switching to native shell. Empty = ask every time, 'shell' = default shell, or set any configured AI tool name such as 'opencode', 'claude-code', or 'codex'"
        },
        "opencodeTui.tmuxSessionDefault": {
          "type": "string",
          "default": "",
          "description": "Default behavior when creating a new tmux session. Empty = ask every time, 'shell' = create without launching a tool, or set any configured AI tool name"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build-and-install": "npx @vscode/vsce package -o build/extension.vsix && code --install-extension build/extension.vsix --force"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.2.0-beta.11"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@types/vscode": "^1.106.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^29.0.1",
    "prettier": "^3.7.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.0"
  }
}
